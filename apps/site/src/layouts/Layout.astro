---
import "../styles/global.css";
import PostHog from "../components/posthog.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <meta
      name="description"
      content="Write docs once. Humans understand them. AI agents actually parse them. Open-source, self-host or cloud."
    />
    <title>Shiru - Stop feeding your AI bad documentation</title>

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Shiru - Stop feeding your AI bad documentation" />
    <meta property="og:description" content="Write docs once. Humans understand them. AI agents actually parse them. Open-source, self-host or cloud." />
    <meta property="og:image" content="/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Shiru - Stop feeding your AI bad documentation" />
    <meta name="twitter:description" content="Write docs once. Humans understand them. AI agents actually parse them. Open-source, self-host or cloud." />
    <meta name="twitter:image" content="/og.png" />
    <PostHog />
  </head>
  <body>
    <slot />
  </body>
</html>
