---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <nav class="mx-auto flex max-w-3xl items-center justify-between px-6 pt-8 pb-4">
    <a href="/" class="flex items-center gap-2.5 no-underline">
      <svg
        width="18"
        height="18"
        viewBox="0 0 18 18"
        fill="none"
        class="shrink-0"
      >
        <path d="M8.99999 15.051C9.16999 15.051 9.33899 15.006 9.49399 14.917C10.137 14.546 11.226 14.07 12.635 14.072C13.534 14.073 14.302 14.269 14.905 14.507C15.553 14.762 16.249 14.267 16.249 13.57V4.48701C16.249 4.13301 16.068 3.80701 15.763 3.62701C15.126 3.25101 14.037 2.76401 12.623 2.76401C10.733 2.76401 9.42499 3.63601 8.99899 3.94601" fill="oklch(52% 0.15 205 / 20%)" stroke="var(--fg)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        <path d="M9.00001 15.051C8.83001 15.051 8.66101 15.006 8.50601 14.917C7.86301 14.546 6.77401 14.07 5.36501 14.072C4.46601 14.073 3.69801 14.269 3.09501 14.507C2.44701 14.762 1.75101 14.27 1.75101 13.574C1.75101 10.981 1.75101 6.10201 1.75101 4.48401C1.75101 4.13001 1.93201 3.80801 2.23701 3.62801C2.87401 3.25201 3.96301 2.76501 5.37701 2.76501C7.26701 2.76501 8.57501 3.63701 9.00101 3.94701V15.051H9.00001Z" stroke="var(--fg)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none" />
      </svg>
      <span class="text-sm font-semibold tracking-tight">Shiru</span>
    </a>

    <a
      href="https://github.com/mahou-labs/shiru"
      target="_blank"
      rel="noopener noreferrer"
      class="rounded-sm text-sm text-fg-muted no-underline transition-colors hover:text-fg focus-visible:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:ring-offset-2"
    >
      GitHub
    </a>
  </nav>

  <main class="mx-auto flex max-w-3xl flex-col items-center px-6 pt-20 pb-20 sm:pt-28 md:pt-36">

    <p class="mb-10 text-sm font-medium text-fg-subtle">
      Open-Source &middot; Self-Hostable &middot; Coming Soon
    </p>

    <h1
      class="mb-5 max-w-2xl text-center font-bold leading-[1.08] tracking-[-0.035em]"
      style="font-size: clamp(2.5rem, 6vw, 4rem);"
    >
      Stop feeding your AI bad documentation
    </h1>

    <p class="mb-12 max-w-xs text-center text-lg leading-relaxed text-fg-muted sm:max-w-sm">
      Write docs once. Humans understand them.
      AI agents actually parse them.
    </p>

    <form
      id="waitlist-form"
      class="flex w-full max-w-md items-center gap-1 rounded-xl border border-border bg-bg-elevated p-1 shadow-sm transition-opacity duration-150"
    >
      <input
        type="email"
        id="email-input"
        name="email"
        placeholder="you@company.com"
        required
        class="min-w-0 flex-1 border-none bg-transparent px-4 py-2.5 text-base text-fg outline-none placeholder:text-fg-subtle/50 focus:outline-none"
        aria-label="Email address"
      />
      <button
        type="submit"
        id="submit-button"
        class="cursor-pointer whitespace-nowrap rounded-lg bg-brand px-5 py-2.5 text-sm font-semibold text-brand-fg transition-colors hover:bg-brand/85 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50"
      >
        Join Waitlist
      </button>
    </form>

    <div
      id="success-message"
      class="mt-1 hidden w-full max-w-md items-center justify-center rounded-xl border border-border bg-bg-elevated p-4 text-center text-sm font-medium text-fg-muted"
    >
      You're on the list &mdash; we'll be in touch.
    </div>

    <p class="mt-4 text-center text-xs text-fg-subtle">
      We'll notify you when early access opens.
    </p>
  </main>

  <footer class="mx-auto flex max-w-3xl flex-col items-center gap-3 px-6 py-10">
    <a
      href="https://x.com/nchartiot"
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-2 rounded-sm text-xs font-medium text-fg-subtle no-underline transition-colors hover:text-fg focus-visible:text-fg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand/40 focus-visible:ring-offset-2"
    >
      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
      </svg>
      <span>Follow for updates</span>
    </a>
    <span class="text-xs text-fg-subtle">
      &copy; 2025&ndash;2026 Mahou Labs
    </span>
  </footer>

  <script>
    import { orpc } from "../utils/orpc-client";

    declare global {
      interface Window {
        posthog?: {
          capture: (
            event: string,
            properties?: Record<string, unknown>,
          ) => void;
        };
      }
    }

    const form = document.getElementById("waitlist-form") as HTMLFormElement;
    const emailInput = document.getElementById("email-input") as HTMLInputElement;
    const submitButton = document.getElementById("submit-button") as HTMLButtonElement;
    const successMessage = document.getElementById("success-message") as HTMLDivElement;

    emailInput.addEventListener(
      "focus",
      () => {
        window.posthog?.capture("waitlist_attempt");
      },
      { once: true },
    );

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const email = emailInput.value;
      submitButton.disabled = true;
      emailInput.disabled = true;
      submitButton.textContent = "Submitting...";

      try {
        await orpc.waitlist.addEmail({ email });
        window.posthog?.capture("waitlist_success");
        form.style.opacity = "0";
        form.style.pointerEvents = "none";
        setTimeout(() => {
          form.style.display = "none";
          successMessage.classList.remove("hidden");
          successMessage.classList.add("flex");
        }, 150);
      } catch (error) {
        // oxlint-disable-next-line no-console
        console.error("Failed to add email to waitlist:", error);
        submitButton.disabled = false;
        emailInput.disabled = false;
        submitButton.textContent = "Join Waitlist";
        // oxlint-disable-next-line no-alert
        alert("Something went wrong, please try again later.");
      }
    });
  </script>
</Layout>
