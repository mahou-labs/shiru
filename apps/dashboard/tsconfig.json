{
  "include": ["**/*.ts", "**/*.tsx"],
  "references": [{ "path": "../api" }],
  "compilerOptions": {
    "target": "ES2025",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2025", "DOM", "DOM.Iterable"],

    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "noEmit": true,

    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
