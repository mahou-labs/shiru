{
  "name": "shiru",
  "private": true,
  "scripts": {
    "dev": "turbo dev db:studio --parallel",
    "dev:email": "turbo dev email db:studio --parallel",
    "dev:dashboard": "turbo -F dashboard dev",
    "dev:dashboard-old": "turbo -F dashboard-old dev",
    "dev:api": "turbo -F api dev",
    "dev:native": "turbo -F native dev",
    "db:studio": "turbo -F api db:studio",
    "update": "pnpm update --interactive --recursive --latest",
    "check": "turbo check",
    "build": "turbo build",
    "db:push": "turbo -F api db:push",
    "db:generate": "turbo -F api db:generate",
    "db:migrate": "turbo -F api db:migrate"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "turbo": "2.8.20",
    "vite-plus": "^0.1.13"
  },
  "engines": {
    "node": ">=24.14.0"
  },
  "packageManager": "pnpm@10.12.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "nucleo-ui-outline-18",
      "nucleo-ui-outline-duo-18",
      "nucleo-core-outline-24"
    ],
    "overrides": {
      "vite": "^8.0.0"
    }
  }
}
